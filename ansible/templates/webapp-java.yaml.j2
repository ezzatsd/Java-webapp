apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}
  namespace: {{ app_namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ app_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ app_name }}
    spec:
      containers:
        - name: {{ app_name }}
          image: {{ app_image }}
          imagePullPolicy: IfNotPresent
          env:
            - name: JAVA_OPTS
              value: "-XX:MaxRAMPercentage=70 -XX:InitialRAMPercentage=30"
          ports:
            - name: http
              containerPort: 8080
          resources:
            requests:
              cpu: 50m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 768Mi
---
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name }}
  namespace: {{ app_namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ app_name }}
  ports:
    - name: http
      port: 80
      targetPort: http
      protocol: TCP
